@model Pokedex.Models.PokedexIndexViewModel
@{
    ViewData["Title"] = "Pokédex";
    Layout = "_Layout";
}

<!-- Pokémon-ish fonts -->
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Montserrat:wght@400;700&display=swap"
    rel="stylesheet" />
<!-- Our Pokédex styles (we'll add this file shortly) -->
<link rel="stylesheet" href="~/css/pokedex.css" />

<div class="pokedex-container">
    <header class="pokedex-header">
        <h1>Pokédex</h1>

        <form method="get" asp-action="Index" class="pokedex-search">
            <input type="text" name="searchName" value="@Model.SearchName"
                placeholder="Search by name (e.g., pikachu)" />

            <select name="selectedType">
                <option value="">All Types</option>
                @foreach (var t in Model.AllTypes)
                {
                    var isSelected = (Model.SelectedType ?? "")
                    .Equals(t, System.StringComparison.OrdinalIgnoreCase);
                    <option value="@t" selected="@(isSelected ? "selected" : null)">@t</option>
                }
            </select>

            <button type="submit">Search</button>
        </form>
    </header>

    <section class="pokedex-grid">
        @if (Model.Results == null || Model.Results.Count == 0)
        {
            <div class="empty-state">No Pokémon found. Try another search.</div>
        }
        else
        {
            foreach (var p in Model.Results)
            {
                <!-- Flexbox card; image is intentionally in the top-left area -->
                <a class="pokemon-card" asp-controller="Pokedex" asp-action="Index" asp-route-searchName="@p.Name.ToLower()">
                    <div class="pokemon-card-left">
                        <img class="pokemon-image" src="@p.ImageUrl" alt="@p.Name" />
                    </div>
                    <div class="pokemon-card-right">
                        <div class="pokemon-header">
                            <span class="pokemon-id">#@p.Id</span>
                            <h2 class="pokemon-name">@p.Name</h2>
                        </div>
                        <div class="pokemon-types">
                            @foreach (var type in p.Types)
                            {
                                var t = (type ?? "").ToLowerInvariant();
                                var style = t switch
                                {
                                    "fairy" => "background:#EE99AC;color:#000;",
                                    "fire" => "background:#E74C3C;color:#fff;",
                                    "water" => "background:#3498DB;color:#fff;",
                                    "dark" => "background:#000000;color:#fff;",
                                    "steel" => "background:#C0C0C0;color:#000;",
                                    "grass" => "background:#2ECC71;color:#000;",
                                    "bug" => "background:#A3D977;color:#000;",
                                    "dragon" => "background:#D4AF37;color:#000;", // gold
                                    "fighting" => "background:#C49A6C;color:#000;", // light brown
                                    "ground" => "background:#8B5E3C;color:#fff;", // brown
                                    "flying" => "background:#D3D3D3;color:#000;", // light grey
                                    "electric" => "background:#F1C40F;color:#000;", // yellow
                                    "ghost" => "background:#000000;color:#fff;", // black
                                    "ice" => "background:#A2DFF7;color:#000;", // light blue
                                    "normal" => "background:#FFFFFF;color:#000;border:1px solid #ddd;",
                                    "psychic" => "background:#C2185B;color:#fff;", // dark pink
                                    "rock" => "background:#C5C5C5;color:#000;", // light grey
                                    "poison" => "background:#4B0082;color:#fff;", // dark purple
                                    _ => "background:#e0e0e0;color:#000;"
                                };

                                <span style="@style padding:6px 10px; border-radius:999px; font-weight:700; font-size:12px; text-transform:capitalize; margin:2px; display:inline-block;">
                                    @type
                                </span>
                            }
                        </div>


                        <div class="pokemon-abilities">
                            <strong>Abilities:</strong> @string.Join(", ", p.Abilities)
                        </div>

                    </div>
                </a>
            }

            <div class="pokedex-paging">
                @if (Model.HasPrev)
                {
                    <a class="nav-arrow left-arrow" asp-action="Index" asp-route-searchName="@Model.SearchName"
                        asp-route-selectedType="@Model.SelectedType" asp-route-page="@(Model.ClampPage(Model.Page - 1))"
                        asp-route-pageSize="@Model.PageSize">← Prev</a>
                }
                <span class="page-info">Page @Model.Page of @Model.TotalPages</span>
                @if (Model.HasNext)
                {
                    <a class="nav-arrow right-arrow" asp-action="Index" asp-route-searchName="@Model.SearchName"
                        asp-route-selectedType="@Model.SelectedType" asp-route-page="@(Model.ClampPage(Model.Page + 1))"
                        asp-route-pageSize="@Model.PageSize">Next →</a>
                }
            </div>

        }
    </section>
</div>
